# ===== Customer Service Environment Variables =====

# Server
PORT=8082
NODE_ENV=development
LOG_LEVEL=info

# LLM (Gemini) — customer-service chỉ dùng LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# Required bởi envConfigSchema dùng chung (không dùng trực tiếp)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=customer_service
