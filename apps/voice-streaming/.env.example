# ===== Voice Streaming Environment Variables =====

# AI Service URL — trỏ tới ai-service
AI_SERVICE_URL=http://localhost:8081

# Client timeout (seconds)
AI_SERVICE_TIMEOUT=10.0

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30.0

# STT streaming (goes through ai-service, no Deepgram SDK needed)
STT_PROVIDER=deepgram
STT_ENABLED=true

# Logging
LOG_LEVEL=INFO

# Webhook / RTP config
WEBHOOK_SECRET=your-secret-here
SESSION_IDLE_TIMEOUT=60
RTP_PORT=5004
CONTROL_PORT=7000
