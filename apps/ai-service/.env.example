# ===== AI Service Environment Variables =====

# Server
PORT=8081
NODE_ENV=development
LOG_LEVEL=info

# LLM (Gemini)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=

# TTS (ElevenLabs)
TTS_PROVIDER=elevenlabs
TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_API_KEY=

# STT (OpenAI Whisper)
STT_PROVIDER=openai
STT_MODEL=whisper-1
OPENAI_API_KEY=

# Realtime (OpenAI) — dùng chung OPENAI_API_KEY
REALTIME_PROVIDER=openai
REALTIME_MODEL=gpt-4o-realtime-preview

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=ai_platform
