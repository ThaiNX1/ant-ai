# ===== Lesson Service Environment Variables =====

# Server
PORT=8083
NODE_ENV=development
LOG_LEVEL=info

# LLM (Gemini)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=

# TTS (ElevenLabs)
TTS_PROVIDER=elevenlabs
TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_API_KEY=

# STT (OpenAI Whisper)
STT_PROVIDER=openai
STT_MODEL=whisper-1
OPENAI_API_KEY=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=ai_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883

# Azure Speech (Pronunciation Assessment)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
