{
  "name": "ai-core",
  "sourceRoot": "libs/ai-core/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/ai-core",
        "main": "libs/ai-core/src/index.ts",
        "tsConfig": "libs/ai-core/tsconfig.lib.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/ai-core/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
